{
  "name": "@pkgdocs/next-adapter",
  "version": "0.0.0",
  "description": "nextjs adapter utilities for pkgdocs",
  "keywords": [
    "pkgdocs",
    "documentation",
    "docs",
    "generator"
  ],
  "author": "noxify",
  "homepage": "https://pkgdocs.dev",
  "bugs": "https://github.com/noxify/pkgdocs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxify/pkgdocs",
    "directory": "packages/next-adapter"
  },
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./framework": {
      "types": "./dist/framework.d.mts",
      "import": "./dist/framework.mjs",
      "default": "./dist/framework.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "clean:cache": "git clean -xdf .cache",
    "dev": "tsdown --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@pkgdocs/prettier-config",
  "dependencies": {
    "@pkgdocs/ui": "workspace:*",
    "rehype-mdx-import-media": "1.4.0",
    "remark-frontmatter": "5.0.0",
    "remark-mdx-frontmatter": "5.2.0",
    "remark-squeeze-paragraphs": "6.0.0",
    "remark-strip-badges": "7.0.0"
  },
  "devDependencies": {
    "@next/mdx": "16.1.6",
    "@pkgdocs/eslint-config": "workspace:*",
    "@pkgdocs/prettier-config": "workspace:*",
    "@pkgdocs/tsconfig": "workspace:*",
    "@renoun/mdx": "3.8.1",
    "@types/node": "24.12.0",
    "eslint": "9.39.4",
    "next": "16.1.6",
    "react": "19.2.4",
    "renoun": "11.4.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "@next/mdx": ">=16.1.6 <17",
    "@renoun/mdx": "3.8.1",
    "next": ">=16.1.6 <17",
    "renoun": "11.4.0"
  }
}

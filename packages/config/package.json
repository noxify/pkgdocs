{
  "name": "@pkgdocs/config",
  "version": "0.0.0",
  "description": "Configuration management for pkgdocs",
  "author": "noxify",
  "keywords": [
    "pkgdocs",
    "documentation",
    "config",
    "configuration"
  ],
  "homepage": "https://pkgdocs.dev",
  "bugs": "https://github.com/noxify/pkgdocs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxify/pkgdocs",
    "directory": "packages/config"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "clean:cache": "git clean -xdf .cache",
    "dev": "tsdown --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@pkgdocs/prettier-config",
  "peerDependencies": {
    "better-themes": ">=1.1.0 <2",
    "renoun": "11.4.0"
  },
  "devDependencies": {
    "@pkgdocs/eslint-config": "workspace:*",
    "@pkgdocs/prettier-config": "workspace:*",
    "@pkgdocs/tsconfig": "workspace:*",
    "@pkgdocs/ui": "workspace:*",
    "@types/node": "24.12.0",
    "better-themes": "1.1.0",
    "eslint": "9.39.4",
    "renoun": "11.4.0",
    "tsdown": "0.21.2",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "valibot": "^1.2.0"
  }
}

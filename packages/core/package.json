{
  "name": "@pkgdocs/core",
  "version": "0.0.0",
  "description": "Core package for pkgdocs",
  "keywords": [
    "pkgdocs",
    "documentation",
    "docs",
    "generator"
  ],
  "homepage": "https://pkgdocs.dev",
  "bugs": "https://github.com/noxify/pkgdocs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxify/pkgdocs",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "noxify",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "clean:cache": "git clean -xdf .cache",
    "dev": "tsdown --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@pkgdocs/prettier-config",
  "devDependencies": {
    "@mdx-js/rollup": "3.1.1",
    "@pkgdocs/eslint-config": "workspace:*",
    "@pkgdocs/prettier-config": "workspace:*",
    "@pkgdocs/tsconfig": "workspace:*",
    "@types/node": "24.12.0",
    "dedent": "1.7.2",
    "eslint": "9.39.4",
    "memfs": "4.56.11",
    "react": "19.2.4",
    "renoun": "11.5.0",
    "tsdown": "0.21.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "react": ">=19.2.4 <20",
    "renoun": "11.4.0",
    "zod": ">=4.3.6 <5"
  }
}

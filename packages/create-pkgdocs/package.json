{
  "name": "create-pkgdocs",
  "version": "0.0.0",
  "description": "Create pkgdocs with one command",
  "keywords": [
    "pkgdocs",
    "documentation",
    "docs",
    "cli",
    "create"
  ],
  "homepage": "https://pkgdocs.dev",
  "bugs": "https://github.com/noxify/pkgdocs/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noxify/pkgdocs.git",
    "directory": "packages/create-pkgdocs"
  },
  "license": "MIT",
  "author": "noxify",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "bin": {
    "create-pkgdocs": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "clean:cache": "git clean -xdf .cache",
    "dev": "tsx src/index.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@pkgdocs/prettier-config",
  "dependencies": {
    "@antfu/install-pkg": "1.1.0",
    "@clack/prompts": "1.1.0",
    "giget": "3.1.2",
    "picocolors": "1.1.1",
    "read-pkg": "10.1.0",
    "terminal-link": "5.0.0"
  },
  "devDependencies": {
    "@pkgdocs/eslint-config": "workspace:*",
    "@pkgdocs/prettier-config": "workspace:*",
    "@pkgdocs/tsconfig": "workspace:*",
    "@types/node": "24.10.4",
    "eslint": "9.39.2",
    "prettier": "3.8.1",
    "tsdown": "0.21.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "@pkgdocs/components",
  "version": "0.0.0",
  "description": "Shared components package for pkgdocs",
  "keywords": [
    "pkgdocs",
    "documentation",
    "docs",
    "generator"
  ],
  "homepage": "https://pkgdocs.dev",
  "bugs": "https://github.com/noxify/pkgdocs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxify/pkgdocs",
    "directory": "packages/components"
  },
  "license": "MIT",
  "author": "noxify",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "_build": "tsdown",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "clean:cache": "git clean -xdf .cache",
    "dev": "tsdown --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@pkgdocs/prettier-config",
  "dependencies": {
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@pkgdocs/eslint-config": "workspace:*",
    "@pkgdocs/prettier-config": "workspace:*",
    "@pkgdocs/tsconfig": "workspace:*",
    "@types/node": "24.10.4",
    "@vitejs/plugin-react": "^5.1.2",
    "dedent": "1.7.2",
    "eslint": "9.39.2",
    "memfs": "^4.56.11",
    "react": "19.2.4",
    "renoun": "11.4.0",
    "tsdown": "0.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.2",
    "renoun": "11.0.0",
    "zod": "^4"
  }
}

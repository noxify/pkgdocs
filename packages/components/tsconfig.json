{
  "extends": "@pkgdocs/tsconfig/internal-package.json",
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src",
    "tests",
    "*.config.ts",
    "types"
  ],
  "exclude": [
    "node_modules"
  ]
}